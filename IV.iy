    ["PluginName"] = "IV",
    ["PluginDescription"] = "Basically a IY plugin.",
    ["Commands"] = {
        ["ivtest"] = {
            ["ListName"] = "IVT [text]",
            ["Description"] = "Outputs text to the Roblox console",
            ["Aliases"] = {"IVP", "vt", "IVT"},
            ["Function"] = function(args, speaker)
                print(getstring(1, args))
            end
