        ["ivh"] = {
            ["ListName"] = "IVH",
            ["Description"] = "Opens IV Hub (Best hub out there)",
            ["Aliases"] = {"hub"},
            ["Function"] = function(args, speaker)
                loadstring(game:HttpGet("https://raw.githubusercontent.com/real-vision/IVH/refs/heads/main/src.lua"))()
